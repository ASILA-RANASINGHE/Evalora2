generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserRole {
  STUDENT
  TEACHER
  PARENT
  ADMIN
}

enum QuestionType {
  MCQ
  SHORT
}

enum QuizType {
  TOPIC_BASED
  UNIT_REVIEW
  DIAGNOSTIC
  PRACTICE
}

enum ContentStatus {
  DRAFT
  PENDING
  APPROVED
  FLAGGED
}

enum ContentVisibility {
  PUBLIC
  PRIVATE
  STUDENTS_ONLY
}

enum PaperTerm {
  TERM_1
  TERM_2
  TERM_3
  MID_YEAR
  END_OF_YEAR
}

enum RelationshipType {
  TEACHER_STUDENT
  PARENT_STUDENT
}

enum RelationshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  firstName String?
  lastName  String?
  role      UserRole @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentDetails StudentDetails?
  teacherDetails TeacherDetails?
  parentDetails  ParentDetails?
  adminDetails   AdminDetails?

  // Content created by this user (teacher/admin)
  createdQuizzes    Quiz[]
  createdPapers     Paper[]
  createdNotes      Note[]
  createdShortNotes ShortNote[]

  // Student attempts
  quizAttempts  QuizAttempt[]
  paperAttempts PaperAttempt[]

  // Student progress
  progress StudentProgress?

  // Relationship requests
  sentRequests     RelationshipRequest[] @relation("SentRequests")
  receivedRequests RelationshipRequest[] @relation("ReceivedRequests")

  // Teacher-Student links
  teacherStudents TeacherStudentLink[] @relation("TeacherToStudents")
  studentTeachers TeacherStudentLink[] @relation("StudentToTeachers")

  // Parent-Student links
  parentStudents ParentStudentLink[] @relation("ParentToStudents")
  studentParents ParentStudentLink[] @relation("StudentToParents")
}

model StudentDetails {
  id        String   @id @db.Uuid
  grade     String
  dob       DateTime?
  studentId String?

  profile Profile @relation(fields: [id], references: [id], onDelete: Cascade)
}

model TeacherDetails {
  id         String  @id @db.Uuid
  subject    String
  employeeId String?
  department String?

  profile Profile @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ParentDetails {
  id           String @id @db.Uuid
  phoneNumber  String
  relationship String

  profile Profile @relation(fields: [id], references: [id], onDelete: Cascade)
}

model AdminDetails {
  id         String  @id @db.Uuid
  department String?

  profile Profile @relation(fields: [id], references: [id], onDelete: Cascade)
}

// ─── Relationships ──────────────────────────────────────────────

model RelationshipRequest {
  id          String             @id @default(uuid()) @db.Uuid
  type        RelationshipType
  status      RelationshipStatus @default(PENDING)
  requesterId String             @db.Uuid
  receiverId  String             @db.Uuid
  createdAt   DateTime           @default(now())
  respondedAt DateTime?

  requester Profile @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  Profile @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId, type])
  @@index([requesterId, status])
  @@index([receiverId, status])
}

model TeacherStudentLink {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @db.Uuid
  studentId String   @db.Uuid
  createdAt DateTime @default(now())

  teacher Profile @relation("TeacherToStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  student Profile @relation("StudentToTeachers", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
}

model ParentStudentLink {
  id        String   @id @default(uuid()) @db.Uuid
  parentId  String   @db.Uuid
  studentId String   @db.Uuid
  createdAt DateTime @default(now())

  parent  Profile @relation("ParentToStudents", fields: [parentId], references: [id], onDelete: Cascade)
  student Profile @relation("StudentToParents", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

// ─── Content: Subjects ───────────────────────────────────────────

model Subject {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique // "Mathematics", "Physics", etc.
  code String @unique // "MATH", "PHY", etc.

  quizzes    Quiz[]
  papers     Paper[]
  notes      Note[]
  shortNotes ShortNote[]
}

// ─── Content: Quizzes ────────────────────────────────────────────

model Quiz {
  id        String     @id @default(uuid()) @db.Uuid
  title     String
  subjectId String     @db.Uuid
  topic     String
  type      QuizType   @default(TOPIC_BASED)
  duration  Int        // minutes
  visibility ContentVisibility @default(STUDENTS_ONLY)
  status    ContentStatus @default(DRAFT)

  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject   Subject       @relation(fields: [subjectId], references: [id])
  createdBy Profile       @relation(fields: [createdById], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String       @id @default(uuid()) @db.Uuid
  quizId        String       @db.Uuid
  text          String
  type          QuestionType @default(MCQ)
  points        Int          @default(1)
  options       String[]     // e.g. ["Option A", "Option B", "Option C", "Option D"]
  correctAnswer String
  order         Int          @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        String    @id @default(uuid()) @db.Uuid
  quizId    String    @db.Uuid
  studentId String    @db.Uuid
  answers   Json?     // { "questionId": "selectedAnswer", ... }
  score     Float?
  startedAt DateTime  @default(now())
  submittedAt DateTime?

  quiz    Quiz    @relation(fields: [quizId], references: [id])
  student Profile @relation(fields: [studentId], references: [id])
}

// ─── Content: Papers ─────────────────────────────────────────────

model Paper {
  id             String    @id @default(uuid()) @db.Uuid
  title          String
  subjectId      String    @db.Uuid
  term           PaperTerm
  grade          String    // "Grade 10", etc.
  year           Int?      // e.g. 2024
  duration       Int       // minutes
  isModel        Boolean   @default(false)

  mcqCount       Int       @default(0)
  mcqMarks       Int       @default(1) // marks per MCQ
  essayCount     Int       @default(0)
  essayMarks     Int       @default(10) // marks per essay
  totalMarks     Int
  passPercentage Int       @default(35)

  instructions     String?
  selectionRules   Json?     // [{ id, label, questionNumbers: number[], required: number }]
  visibility       ContentVisibility @default(STUDENTS_ONLY)
  status           ContentStatus @default(DRAFT)

  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject   Subject          @relation(fields: [subjectId], references: [id])
  createdBy Profile          @relation(fields: [createdById], references: [id])
  questions PaperQuestion[]
  attempts  PaperAttempt[]
}

model PaperQuestion {
  id             String       @id @default(uuid()) @db.Uuid
  paperId        String       @db.Uuid
  text           String
  type           QuestionType @default(MCQ)
  points         Int          @default(1)
  options        String[]
  correctAnswer  String
  order          Int          @default(0)

  // Structured question hierarchy
  questionNumber Int?     // main question group number (e.g. 1, 2, 3)
  subLabel       String?  // first-level sub label (e.g. "a", "b", "c")
  subSubLabel    String?  // second-level sub label (e.g. "i", "ii", "iii")
  description    String?  // optional description shown at the top of a main question group

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model PaperAttempt {
  id          String    @id @default(uuid()) @db.Uuid
  paperId     String    @db.Uuid
  studentId   String    @db.Uuid
  score       Float?
  timeTaken   Int?      // seconds
  answers     Json?     // { "questionId": "answer" }
  flagged     Json?     // ["questionId", ...]
  results     Json?     // full per-question results object
  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  paper   Paper   @relation(fields: [paperId], references: [id])
  student Profile @relation(fields: [studentId], references: [id])
}

// ─── Content: Notes ──────────────────────────────────────────────

model Note {
  id         String            @id @default(uuid()) @db.Uuid
  title      String
  subjectId  String            @db.Uuid
  grade      String?
  topic      String
  content    String            // markdown or rich text — TEXT has no size limit
  visibility ContentVisibility @default(STUDENTS_ONLY)
  status     ContentStatus     @default(DRAFT)

  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject          @relation(fields: [subjectId], references: [id])
  createdBy   Profile          @relation(fields: [createdById], references: [id])
  attachments NoteAttachment[]
}

model NoteAttachment {
  id     String @id @default(uuid()) @db.Uuid
  noteId String @db.Uuid
  name   String
  url    String // Supabase Storage URL
  size   Int    // bytes
  type   String // MIME type

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// ─── Content: Short Notes ───────────────────────────────────────

model ShortNote {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  subjectId   String        @db.Uuid
  grade       String?
  topic       String
  content     String
  visibility  ContentVisibility @default(STUDENTS_ONLY)
  status      ContentStatus     @default(DRAFT)

  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject               @relation(fields: [subjectId], references: [id])
  createdBy   Profile               @relation(fields: [createdById], references: [id])
  attachments ShortNoteAttachment[]
}

model ShortNoteAttachment {
  id          String    @id @default(uuid()) @db.Uuid
  shortNoteId String    @db.Uuid
  name        String
  url         String    // Supabase Storage URL
  size        Int       // bytes
  type        String    // MIME type

  shortNote ShortNote @relation(fields: [shortNoteId], references: [id], onDelete: Cascade)
}

// ─── Historical Locations (Map Search) ──────────────────────────

model Location {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  latitude    Float
  longitude   Float
  description String?
  category    String? // e.g. "ancient_city", "kingdom", "temple", "colonial_fort"
}

// ─── Student Progress & Gamification ─────────────────────────────

model StudentProgress {
  id               String @id @default(uuid()) @db.Uuid
  studentId        String @unique @db.Uuid
  quizzesCompleted Int    @default(0)
  papersAttempted  Int    @default(0)
  averageScore     Float  @default(0)
  studyStreak      Int    @default(0)
  totalPoints      Int    @default(0)
  totalLearningMin Int    @default(0) // total minutes spent
  topicsMastered   Int    @default(0)
  updatedAt        DateTime @updatedAt

  student Profile @relation(fields: [studentId], references: [id])
}

model DocumentChunk {
  id        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  topic     String?
  content   String
  grade     String?
  embedding Unsupported("vector(384)")?
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
}